# ─────────────────────────────────────────────
# ZONFORGE SENTINEL — Environment Configuration
# Copy to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
ZONFORGE_ENV=development
ZONFORGE_LOG_LEVEL=debug
ZONFORGE_API_URL=http://localhost:3000

# ── PostgreSQL ────────────────────────────────
ZONFORGE_POSTGRES_HOST=localhost
ZONFORGE_POSTGRES_PORT=5432
ZONFORGE_POSTGRES_DB=zonforge
ZONFORGE_POSTGRES_USER=zonforge
ZONFORGE_POSTGRES_PASSWORD=changeme_local
ZONFORGE_POSTGRES_SSL=false
ZONFORGE_POSTGRES_POOL_MIN=2
ZONFORGE_POSTGRES_POOL_MAX=20

# ── ClickHouse ────────────────────────────────
ZONFORGE_CLICKHOUSE_HOST=http://localhost:8123
ZONFORGE_CLICKHOUSE_DB=zonforge_events
ZONFORGE_CLICKHOUSE_USER=default
ZONFORGE_CLICKHOUSE_PASSWORD=changeme_local

# ── Redis ─────────────────────────────────────
ZONFORGE_REDIS_HOST=localhost
ZONFORGE_REDIS_PORT=6379
ZONFORGE_REDIS_PASSWORD=changeme_local
ZONFORGE_REDIS_TLS=false

# ── Auth ──────────────────────────────────────
ZONFORGE_JWT_SECRET=changeme_min_32_chars_local_dev_only
ZONFORGE_JWT_ACCESS_EXPIRY=15m
ZONFORGE_JWT_REFRESH_EXPIRY=7d
ZONFORGE_API_KEY_SALT=changeme_min_32_chars_local_dev_only

# ── Encryption ────────────────────────────────
ZONFORGE_ENCRYPTION_KEY=REDACTED_ENV_PLACEHOLDER
ZONFORGE_HMAC_SECRET=changeme_min_32_chars_local_dev_only

# ── AWS ───────────────────────────────────────
ZONFORGE_AWS_REGION=us-east-1
ZONFORGE_AWS_ACCESS_KEY_ID=
ZONFORGE_AWS_SECRET_ACCESS_KEY=
ZONFORGE_S3_BUCKET_EVENTS=zonforge-events-dev
ZONFORGE_S3_BUCKET_EXPORTS=zonforge-exports-dev
ZONFORGE_S3_BUCKET_AUDIT=zonforge-audit-dev

# ── Stripe ────────────────────────────────────
ZONFORGE_STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_PLACEHOLDER
ZONFORGE_STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET_PLACEHOLDER

# ── Anthropic (LLM Narratives) ────────────────
ZONFORGE_ANTHROPIC_API_KEY=ANTHROPIC_API_KEY_PLACEHOLDER

# ── Threat Intel ──────────────────────────────
ZONFORGE_OTX_API_KEY=
ZONFORGE_ABUSEIPDB_API_KEY=

# ── Notifications ─────────────────────────────
ZONFORGE_SENDGRID_API_KEY=
ZONFORGE_SENDGRID_FROM_EMAIL=alerts@zonforge.com

# ── BullMQ ───────────────────────────────────
ZONFORGE_QUEUE_CONCURRENCY=10
ZONFORGE_QUEUE_MAX_RETRIES=3

# ── Feature Flags ────────────────────────────
ZONFORGE_FEATURE_LLM_NARRATIVES=true
ZONFORGE_FEATURE_THREAT_INTEL=true
ZONFORGE_FEATURE_ANOMALY_DETECTION=false

# ── Database URL (Drizzle ORM) ────────────────
ZONFORGE_DATABASE_URL=postgresql://zonforge:changeme_local@localhost:5432/zonforge

# ── Application Base URL ─────────────────────
APP_BASE_URL=http://localhost:5173

# ── AI / Anthropic ────────────────────────────
ANTHROPIC_API_KEY=ANTHROPIC_API_KEY_PLACEHOLDER
ZONFORGE_ANTHROPIC_API_KEY=ANTHROPIC_API_KEY_PLACEHOLDER

# ── Stripe Billing ────────────────────────────
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_PLACEHOLDER
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET_PLACEHOLDER

# ── AWS / S3 ──────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_KEY
ZONFORGE_S3_BUCKET=zonforge-reports-dev

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY
FROM_EMAIL=noreply@zonforge.com

# ── Service Ports (override with PORT env var per service) ───────
PORT_API_GATEWAY=3000
PORT_INGESTION=3001
PORT_NORMALIZATION=3002
PORT_DETECTION=3003
PORT_ANOMALY=3004
PORT_THREAT_INTEL=3005
PORT_CORRELATION=3006
PORT_RISK_SCORING=3007
PORT_ALERT_SERVICE=3008
PORT_PLAYBOOK_ENGINE=3009
PORT_BILLING=3010
PORT_MSSP_CONSOLE=3011
PORT_THREAT_HUNTING=3012
PORT_COMPLIANCE=3013
PORT_REDTEAM=3014
PORT_AI_SOC_ANALYST=3015
PORT_SUPPLY_CHAIN=3016
PORT_DECEPTION_TECH=3017
PORT_REGULATORY_AI=3018
PORT_DIGITAL_TWIN=3019
PORT_BEHAVIORAL_AI=3020
PORT_ALERT_TRIAGE=3021
PORT_SEC_ASSISTANT=3022
PORT_PREDICTIVE=3023
PORT_SSO_SERVICE=3024
PORT_POC_MANAGER=3025

# ── Twilio SMS + WhatsApp ─────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# SMS (Twilio phone number — buy from console)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_DEFAULT_TO=+8801XXXXXXXXX

# WhatsApp
# Dev/Test: use Twilio sandbox number below
# Production: use your approved WhatsApp Business number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_DEFAULT_TO=whatsapp:+8801XXXXXXXXX
