{
  "expo": {
    "name": "ZonForge Sentinel",
    "slug": "zonforge-sentinel",
    "version": "4.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zonforge",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#010a10"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zonforge.sentinel",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for QR code connector setup"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#010a10"
      },
      "package": "com.zonforge.sentinel",
      "permissions": ["NOTIFICATIONS", "INTERNET"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00d9ff",
          "sounds": ["./assets/notification.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl":    "https://api.zonforge.com",
      "appEnv":    "production",
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
