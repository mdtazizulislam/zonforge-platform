{
  "compilerOptions": {
    "target":          "ES2022",
    "lib":             ["ES2022", "DOM", "DOM.Iterable"],
    "module":          "ESNext",
    "moduleResolution":"Bundler",
    "jsx":             "react-jsx",
    "strict":          true,
    "noUnusedLocals":  false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl":         ".",
    "paths":           { "@/*": ["src/*"] },
    "skipLibCheck":    true
  },
  "include": ["src", "src/vite-env.d.ts"]
}
