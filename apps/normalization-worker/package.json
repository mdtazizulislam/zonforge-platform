{
  "name": "@zonforge/normalization-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev":       "node --watch --env-file=../../.env.local dist/index.js",
    "build":     "tsc",
    "start":     "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run",
    "clean":     "rm -rf dist"
  },
  "dependencies": {
    "@zonforge/ingestion-service": "*",
    "@zonforge/shared-types":  "*",
    "@zonforge/event-schema":  "*",
    "@zonforge/db-client":     "*",
    "@zonforge/logger":        "*",
    "@zonforge/config":        "*",
    "bullmq":                  "^5.7.0",
    "ioredis":                 "^5.3.0",
    "uuid":                    "^9.0.0",
    "zod":                     "^3.22.0"
  },
  "devDependencies": {
    "typescript":  "^5.4.0",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.0",
    "vitest":      "^1.5.0"
  }
}
