{
  "uid":   "zonforge-ops",
  "title": "ZonForge Sentinel — Operations",
  "tags":  ["zonforge", "operations"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,

  "templating": {
    "list": [
      {
        "name":  "cluster",
        "label": "Cluster",
        "type":  "query",
        "query": "label_values(up, cluster)",
        "current": { "text": "zonforge-prod" },
        "refresh": 2
      },
      {
        "name":  "service",
        "label": "Service",
        "type":  "query",
        "query": "label_values(up{cluster=\"$cluster\",namespace=\"zonforge\"}, job)",
        "multi": true,
        "includeAll": true,
        "refresh": 2
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "title": "🟢 Service Health",
      "type":  "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [{
        "expr":    "up{namespace='zonforge'}",
        "legendFormat": "{{job}}"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN",    "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" } } }
          ]
        }
      }
    },

    {
      "id": 2,
      "title": "📥 Event Ingestion Rate",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "expr":         "zonforge:events_ingested_rate1m",
          "legendFormat": "Ingested/s"
        },
        {
          "expr":         "zonforge:events_normalized_rate1m",
          "legendFormat": "Normalized/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 3,
      "title": "🚨 Detection Signals Rate",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "expr":         "zonforge:detection_signals_rate5m",
          "legendFormat": "Signals/s"
        },
        {
          "expr":         "zonforge:alerts_created_rate1h / 3600",
          "legendFormat": "Alerts/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },

    {
      "id": 4,
      "title": "⏱️ Pipeline Lag (ms)",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [{
        "expr":         "zonforge_queue_lag_ms",
        "legendFormat": "{{queue}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 60000 },
              { "color": "red",    "value": 120000 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "title": "📊 API Gateway — Request Rate",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [{
        "expr":         "sum(zonforge:http_request_rate5m{job='api-gateway'}) by (method)",
        "legendFormat": "{{method}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },

    {
      "id": 6,
      "title": "📊 API Gateway — Error Rate",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [{
        "expr":         "zonforge:http_error_rate5m{job='api-gateway'}",
        "legendFormat": "Error Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      }
    },

    {
      "id": 7,
      "title": "📊 API Latency (p50/p95/p99)",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr":         "zonforge:http_latency_p50{job='api-gateway'}",
          "legendFormat": "p50"
        },
        {
          "expr":         "zonforge:http_latency_p95{job='api-gateway'}",
          "legendFormat": "p95"
        },
        {
          "expr":         "zonforge:http_latency_p99{job='api-gateway'}",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 2.0 }
            ]
          }
        }
      }
    },

    {
      "id": 8,
      "title": "📦 BullMQ Queue Depths",
      "type":  "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{
        "expr":         "zonforge_queue_waiting",
        "legendFormat": "{{queue}}"
      }],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 1000 },
              { "color": "red",    "value": 10000 }
            ]
          }
        }
      }
    },

    {
      "id": 9,
      "title": "🔴 MTTD Performance",
      "type":  "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr":         "zonforge:mttd_p50_minutes",
          "legendFormat": "P50"
        },
        {
          "expr":         "zonforge:mttd_p90_minutes",
          "legendFormat": "P90"
        },
        {
          "expr":         "zonforge:mttd_p99_minutes",
          "legendFormat": "P99"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "red",    "value": 60 }
            ]
          }
        }
      }
    },

    {
      "id": 10,
      "title": "💾 PostgreSQL — Connections",
      "type":  "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 28 },
      "targets": [
        {
          "expr":         "pg_stat_activity_count{state='active'}",
          "legendFormat": "Active"
        },
        {
          "expr":         "pg_stat_activity_count{state='idle'}",
          "legendFormat": "Idle"
        },
        {
          "expr":         "pg_settings_max_connections",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 11,
      "title": "📌 Redis — Memory & Commands",
      "type":  "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 28 },
      "targets": [
        {
          "expr":         "redis_memory_used_bytes",
          "legendFormat": "Memory Used"
        },
        {
          "expr":         "rate(redis_commands_processed_total[1m])",
          "legendFormat": "Commands/s"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Memory Used" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Commands/s" },
            "properties": [{ "id": "unit", "value": "reqps" }]
          }
        ]
      }
    },

    {
      "id": 12,
      "title": "🖥️ Node CPU & Memory",
      "type":  "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 28 },
      "targets": [
        {
          "expr":         "1 - avg(rate(node_cpu_seconds_total{mode='idle'}[5m]))",
          "legendFormat": "CPU Usage"
        },
        {
          "expr":         "1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes",
          "legendFormat": "Memory Usage"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "red",    "value": 0.9 }
            ]
          }
        }
      }
    }
  ]
}
